---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import getSortedPosts from "@utils/getSortedPosts";
import { SITE, SOCIALS } from "@config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <div class="hero-content">
        <div class="hero-badge">Blog</div>
        <h1>
          Ideas worth<br />
          <span class="hero-accent">reading.</span>
        </h1>
        <p class="hero-desc">
          {SITE.desc}
        </p>
        <div class="hero-actions">
          <LinkButton
            href={`${import.meta.env.BASE_URL}posts/`}
            className="btn-primary"
          >
            Browse all posts
            <svg xmlns="http://www.w3.org/2000/svg" class="btn-icon"
              ><path
                d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
              ></path>
            </svg>
          </LinkButton>
          {
            socialCount > 0 && (
              <div class="hero-socials">
                <Socials />
              </div>
            )
          }
        </div>
      </div>
      <a
        target="_blank"
        href={`${import.meta.env.BASE_URL}rss.xml`}
        class="rss-link"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="rss-icon"
          ><path
            d="M19 20.001C19 11.729 12.271 5 4 5v2c7.168 0 13 5.832 13 13.001h2z"
          ></path><path
            d="M12 20.001h2C14 14.486 9.514 10 4 10v2c4.411 0 8 3.589 8 8.001z"
          ></path><circle cx="6" cy="18" r="2"></circle>
        </svg>
        <span class="sr-only">RSS Feed</span>
      </a>
    </section>

    {
      featuredPosts.length > 0 && (
        <>
          <Hr />
          <section id="featured">
            <div class="section-header">
              <h2>Featured</h2>
            </div>
            <ul class="posts-grid">
              {featuredPosts.map(({ data, slug }) => (
                <Card
                  href={`${import.meta.env.BASE_URL}posts/${slug}/`}
                  frontmatter={data}
                  secHeading={false}
                />
              ))}
            </ul>
          </section>
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <>
          <Hr />
          <section id="recent-posts">
            <div class="section-header">
              <h2>Recent Posts</h2>
              <LinkButton
                href={`${import.meta.env.BASE_URL}posts/`}
                className="view-all-link"
              >
                View all
                <svg xmlns="http://www.w3.org/2000/svg">
                  <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" />
                </svg>
              </LinkButton>
            </div>
            <ul class="posts-grid">
              {recentPosts.slice(0, 6).map(({ data, slug }) => (
                <Card
                  href={`${import.meta.env.BASE_URL}posts/${slug}/`}
                  frontmatter={data}
                  secHeading={false}
                />
              ))}
            </ul>
          </section>
        </>
      )
    }
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply relative py-16 sm:py-24;
  }
  .hero-content {
    @apply max-w-2xl;
  }
  .hero-badge {
    @apply mb-4 inline-flex items-center rounded-full border border-skin-accent border-opacity-40 bg-skin-accent bg-opacity-10 px-3 py-1 text-sm font-medium text-skin-accent;
  }
  #hero h1 {
    @apply mb-6 text-4xl font-extrabold leading-tight tracking-tight sm:text-6xl;
  }
  .hero-accent {
    @apply text-skin-accent;
  }
  .hero-desc {
    @apply mb-8 text-lg leading-relaxed text-skin-base opacity-70;
  }
  .hero-actions {
    @apply flex flex-wrap items-center gap-4;
  }
  .btn-primary {
    @apply inline-flex items-center gap-2 rounded-xl bg-skin-accent px-6 py-3 text-sm font-semibold text-white transition-all duration-200 hover:opacity-90 hover:shadow-lg;
  }
  .btn-icon {
    @apply h-4 w-4 fill-current;
  }
  .hero-socials {
    @apply flex items-center;
  }
  .rss-link {
    @apply absolute right-0 top-6 p-2 opacity-60 transition-opacity hover:opacity-100;
  }
  .rss-icon {
    @apply h-5 w-5 fill-skin-accent;
  }

  /* ===== Section Headers ===== */
  .section-header {
    @apply mb-8 flex items-center justify-between;
  }
  #featured h2,
  #recent-posts h2 {
    @apply text-2xl font-bold tracking-tight;
  }
  .view-all-link {
    @apply inline-flex items-center gap-1 text-sm font-medium text-skin-accent transition-opacity hover:opacity-80;
  }

  /* ===== Posts Grid ===== */
  .posts-grid {
    @apply grid gap-5 sm:grid-cols-2 lg:grid-cols-3;
  }

  /* ===== Featured & Recent Posts Sections ===== */
  #featured,
  #recent-posts {
    @apply pb-10 pt-12;
  }
</style>
