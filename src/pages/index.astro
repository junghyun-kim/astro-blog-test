---
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCard from "@components/PostCard.astro";
import { getAllPosts, CATEGORIES } from "@utils/getAllPosts";
import { SITE } from "@config";

const allPosts = await getAllPosts();
const latestPosts = allPosts.slice(0, 6);
const BASE = import.meta.env.BASE_URL;
---

<BaseLayout title={SITE.title} description={SITE.desc}>
  {/* ===== Hero ===== */}
  <section id="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">큐레이션 매거진</p>
      <h1>
        한 사람의 취향을<br />깊이&nbsp;<em>파는 곳.</em>
      </h1>
      <p class="hero-desc">{SITE.desc}</p>
    </div>
  </section>

  {/* ===== Category nav ===== */}
  <section id="categories">
    <ul class="category-list">
      {
        CATEGORIES.map(({ slug, label, desc }) => (
          <li>
            <a href={`${BASE}${slug}/`} class="category-card group">
              <span class="editorial-label">{label}</span>
              <p class="cat-card-desc">{desc}</p>
              <span class="cat-arrow">→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  {/* ===== Latest posts ===== */}
  {
    latestPosts.length > 0 && (
      <section id="latest">
        <div class="section-header">
          <p class="section-eyebrow">최신 글</p>
        </div>
        <ul class="posts-grid">
          {latestPosts.map(post => (
            <PostCard
              {post}
              href={`${BASE}${post.collection}/${post.slug}/`}
              headingLevel="h2"
            />
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>

<style>
  /* ===== Hero ===== */
  #hero {
    @apply py-24 sm:py-36;
  }
  .hero-inner {
    @apply max-w-xl;
  }
  .hero-eyebrow {
    @apply mb-6 text-[10px] font-medium uppercase tracking-[0.18em] text-skin-accent;
  }
  #hero h1 {
    @apply mb-6 font-serif text-5xl font-light leading-[1.1] tracking-tight
    text-skin-base sm:text-7xl;
  }
  #hero h1 em {
    @apply not-italic text-skin-accent;
  }
  .hero-desc {
    @apply text-base font-light leading-relaxed text-skin-base opacity-60;
  }

  /* ===== Category nav ===== */
  #categories {
    @apply border-t border-skin-line py-16;
  }
  .category-list {
    @apply grid gap-0 sm:grid-cols-5;
  }
  .category-card {
    @apply flex flex-col border-r border-skin-line px-5 py-6 transition-colors
    hover:bg-skin-card last:border-r-0;
  }
  /* On small screens, switch to horizontal borders */
  @media (max-width: 639px) {
    .category-card {
      @apply border-b border-r-0 last:border-b-0;
    }
  }
  .cat-card-desc {
    @apply mt-2 flex-1 text-xs leading-relaxed text-skin-base opacity-50 line-clamp-3;
  }
  .cat-arrow {
    @apply mt-4 self-end text-xs text-skin-accent opacity-0 transition-opacity
    group-hover:opacity-100;
  }

  /* ===== Latest posts ===== */
  #latest {
    @apply border-t border-skin-line py-16;
  }
  .section-header {
    @apply mb-10;
  }
  .section-eyebrow {
    @apply text-[10px] font-medium uppercase tracking-[0.18em] text-skin-accent;
  }
  .posts-grid {
    @apply grid gap-10 sm:grid-cols-2 lg:grid-cols-3;
  }
</style>
